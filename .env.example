# مساعد — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=

# ── AI ───────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=          # Primary AI model
ANTHROPIC_API_KEY=         # Fallback (add credits before use)

# ── WhatsApp Gateway (Green API) ─────────────────────────────────────────────
GREEN_API_INSTANCE=        # e.g. 7107624780
GREEN_API_TOKEN=           # From green-api.com dashboard

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=sanad-postgres
POSTGRES_PORT=5432
POSTGRES_DB=sanad
POSTGRES_USER=sanad
POSTGRES_PASSWORD=
