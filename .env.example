# مساعد — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=

# ── AI ───────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=          # Primary AI model
ANTHROPIC_API_KEY=         # Fallback (add credits before use)

# ── WhatsApp Gateway (Green API) ─────────────────────────────────────────────
MASAED_GREEN_INSTANCE=        # e.g. 7107624780
MASAED_GREEN_TOKEN=           # From green-api.com dashboard
MASAED_BASE_URL=https://masaed.wardyat.net

# ── Safety: Sandbox Phone Numbers ────────────────────────────────────────────
# CRITICAL: Only these phones can receive test/demo messages in dev mode.
# Format: comma-separated list of 966XXXXXXXXX or sandbox numbers (050000000X)
MASAED_SANDBOX_PHONES=966500000000,966500000001,0500000000,0500000001

# DANGER: Set to "true" ONLY when sending to real users in production.
# Default: false (blocks real sends, only allows sandbox).
MASAED_ALLOW_REAL_SEND=false

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=sanad-postgres
POSTGRES_PORT=5432
POSTGRES_DB=sanad
POSTGRES_USER=sanad
POSTGRES_PASSWORD=
